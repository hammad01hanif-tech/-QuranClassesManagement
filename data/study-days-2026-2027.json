  "usage": {
    "description": "استخدم الدوال المتوفرة في study-days-calendar.js للاستعلام عن أيام الدراسة والإجازات",
    "functions": [
      "isStudyDay(date) - فحص إذا كان يوم دراسة",
      "isWeekend(date) - فحص إذا كان إجازة أسبوعية",
      "isOfficialHoliday(date) - فحص إذا كان إجازة رسمية",
      "getDayInfo(date) - الحصول على معلومات كاملة عن يوم معين",
      "getStudyDaysInMonth(year, month) - أيام الدراسة في شهر",
      "countStudyDays(startDate, endDate) - عد أيام الدراسة بين تاريخين",
      "getNextStudyDay(date) - الحصول على يوم الدراسة التالي",
      "getTodayInfo() - معلومات اليوم الحالي"
    ]
  },
  "notes": [
    "التقويم يعمل تلقائياً لأي تاريخ في المستقبل",
    "الإجازة الأسبوعية: الجمعة والسبت دائماً",
    "أيام الدراسة: الأحد إلى الخميس (ما لم تكن في إجازة رسمية)",
    "التواريخ الهجرية مبنية على تقويم أم القرى الرسمي",
    "يمكن إضافة استثناءات خاصة بالحلقة في officialHolidays"
  ]
